# ====== Admin Workspaces（管理后台多项目库）— Git 忽略规则 ======

# ====== 1. 依赖 ======
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ====== 2. 构建产物 ======
dist/
dist-test/
**/dist-test/
build/
out/
.next/
.vite/
.parcel-cache
*.tsbuildinfo

# ====== 3. 本地环境（仅忽略本地覆盖文件） ======
# .env.development / .env.test / .env.production 是公共配置，需要提交
# 只有 .env.local 是本地私密配置（API Key、本地端口等）
.env.local
.env.development.local
.env.test.local
.env.production.local

# ====== 4. IDE / 编辑器 ======
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj

# ====== 5. 缓存 ======
.eslintcache
.stylelintcache
.cache/
test-results/

# ====== 6. AI / 工具 ======
.claude/
.claudeignore
*.zip
